{
  "expo": {
    "name": "KhojMitra",
    "slug": "KhojMitra",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "khojmitra",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "jsEngine": "hermes",
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1976D2",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.vieek.KhojMitra",
      "versionCode": 1
    },
    "web": {
      "output": "server",
      "favicon": "https://www.polytechnique-insights.com/wp-content/uploads/2022/11/space-1024x640.jpeg",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "cover",
           "backgroundColor": "#1976D2"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e4fb7a32-dc45-419e-9c15-853fe296f6a7"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/e4fb7a32-dc45-419e-9c15-853fe296f6a7"
    }
  }
}
